# Configuração do deploy no servidor interno (docker compose).
# Copie para .env e ajuste se necessário:  cp .env.example .env

# Portas publicadas no host (8000 e 8080 já estão em uso).
API_PORT=8001
UI_PORT=8081

# URL que o NAVEGADOR usa para chamar a API. Precisa ser o IP/host
# acessível pelos clientes — é "assado" no build do frontend.
NEXT_PUBLIC_API_URL=http://172.16.10.100:8001

# Origem permitida no CORS (a URL da UI).
CORS_ORIGINS=http://172.16.10.100:8081

# Intervalo das checagens automáticas (minutos).
CHECK_INTERVAL_MINUTES=5
