# Postgres do Railway é injetado automaticamente como DATABASE_URL.
# Para dev local, deixe comentado e o app usa SQLite (local.db).
# DATABASE_URL=postgresql://user:pass@localhost:5432/monitor

# Intervalo das checagens automáticas, em minutos.
CHECK_INTERVAL_MINUTES=5

# Origens permitidas no CORS (a URL do frontend na Vercel).
# Use "*" para liberar tudo enquanto não há auth.
CORS_ORIGINS=*
